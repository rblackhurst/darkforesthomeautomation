# DFHA app environment variables.
#
# Copy to .env on the production server (the bootstrap script does this
# automatically and fills in real values). Never commit a real .env.

# Django core
DJANGO_SECRET_KEY=replace-with-50-char-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=app.darkforesthomeautomation.com

# Database (omit DJANGO_DB_HOST entirely to fall back to local SQLite)
DJANGO_DB_NAME=dfha
DJANGO_DB_USER=dfha
DJANGO_DB_PASSWORD=replace-with-random-password
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432
